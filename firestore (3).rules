rules_version = '2';

// ============================================================
//  Quorum Ordinance Record — Firestore Security Rules
//  Project: eq24-a5fc8
//
//  Only a signed-in account whose email is listed below may
//  read or write the records. Emails MUST be lowercase here —
//  Firebase stores and returns account emails in lowercase, so
//  the comparison has to match that.
//
//  Paste this into:  Firestore Database -> Rules -> Publish
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // --- The authorized presidency members ---
    function isPresidency() {
      return request.auth != null
        && request.auth.token.email in [
            'filipefa1998@gmail.com',   // Filipe (you)
            'stanmoleni@gmail.com',     // Stan Moleni
            'livai.f.mak@gmail.com'     // Livai Makasini
          ];
    }

    // Brethren records: only the presidency may read or write.
    match /brethren/{docId} {
      allow read, write: if isPresidency();
    }

    // Ordinance history log: same presidency-only access.
    match /ledger/{docId} {
      allow read, write: if isPresidency();
    }

    // Everything else: locked.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
