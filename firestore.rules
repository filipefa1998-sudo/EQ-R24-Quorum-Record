rules_version = '2';

// ============================================================
//  Quorum Ordinance Record — Firestore Security Rules
//  Project: eq24-a5fc8
//
//  These rules are the REAL protection. Even someone who finds
//  your page URL or the Firebase config cannot read or write the
//  records unless they are signed in AND their email is listed
//  below. Replace the example emails with your presidency's
//  actual sign-in emails (lowercase), then click Publish.
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // --- The authorized presidency members ---
    function isPresidency() {
      return request.auth != null
        && request.auth.token.email in [
            'filipe@example.com',
            'counselor1@example.com',
            'counselor2@example.com',
            'secretary@example.com'
          ];
    }

    // Brethren records: only the presidency may read or write.
    match /brethren/{docId} {
      allow read, write: if isPresidency();
    }

    // Everything else: locked.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
